  "dynamicRoutes": [
    {
      "page": "/doctors/[slug]",
      "regex": "^/doctors/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/doctors/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/services/[slug]",
